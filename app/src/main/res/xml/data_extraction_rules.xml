<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="covers/" />
        <!-- Keep Keystore-encrypted WebDAV credentials on-device only. -->
        <exclude domain="sharedpref" path="sync_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="covers/" />
        <include domain="database" path="ebook_reader.db" />
        <exclude domain="sharedpref" path="sync_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
